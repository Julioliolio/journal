# Turso database (libSQL). For local development, you can use a file URL:
#   TURSO_DATABASE_URL=file:./local.db
# For production, paste your Turso URL and auth token.
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Vercel Blob read/write token (get this from the Vercel dashboard → Storage → your Blob store).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Secret slug for the authoring URL: /login/<AUTHOR_LINK_TOKEN>
# Pick something long and unguessable (e.g. `openssl rand -hex 24`).
# Anyone with this URL can claim a partner slot, so treat it like a password.
AUTHOR_LINK_TOKEN=replace-me-with-a-long-random-string
